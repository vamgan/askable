{
  "name": "@askable-ui/angular",
  "version": "0.1.0",
  "description": "Angular bindings for askable — LLM-aware UI context",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
